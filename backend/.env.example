# Copy this file to .env and fill in values for local development.
# Railway and Render inject these automatically in the cloud.

# Port the server listens on (Railway/Render override this automatically)
PORT=8000

# CORS allowed origins — comma-separated list, or * for all
# Example for production: ALLOWED_ORIGINS=https://yourextension.chromiumapp.org
ALLOWED_ORIGINS=*

# Session & API Key secrets — CHANGE THESE in production!
# Generate a strong random secret with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-please-use-a-real-secret
API_KEY_SALT=phishguard-api-salt-2026

# Gemini API Key — get one at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-key-here

